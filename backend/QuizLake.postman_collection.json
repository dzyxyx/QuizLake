              "raw": "{\n  \"scheduled_start_at\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/quizzes/{{quiz_id}}/sessions",
              "host": ["{{base_url}}"],
              "path": ["quizzes", "{{quiz_id}}", "sessions"]
            },
            "description": "Требует, чтобы квиз был в статусе ready (см. Quizzes -> Update quiz)."
          }
        },
        {
          "name": "Get discover feed",
          "request": {
